<?xml version="1.0" encoding="utf-8"?>
<!--
  Themed-icon (Android 13+) layer. The system uses ONLY the alpha channel and
  tints it, so the centerline dashes are cut out of the road via evenOdd fill
  (painting them as a second color would render as one solid slab).
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Road with dash cutouts -->
    <path
        android:fillColor="#FFFFFF"
        android:fillType="evenOdd"
        android:pathData="M43,84 L50.5,42 L57.5,42 L65,84 Z
                          M52.6,80 L55.4,80 L55.1,71 L52.9,71 Z
                          M53,65.5 L55,65.5 L54.8,58 L53.2,58 Z
                          M53.35,53.5 L54.65,53.5 L54.55,47.5 L53.45,47.5 Z" />

    <!-- Radar beacon dot -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M54,35 m-4.2,0 a4.2,4.2 0 1 1 8.4,0 a4.2,4.2 0 1 1 -8.4,0" />

    <!-- Radar arcs -->
    <path
        android:pathData="M47.64,28.64 A9,9 0 0 1 60.36,28.64"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="3.5"
        android:strokeLineCap="round"
        android:fillColor="#00000000" />
    <path
        android:pathData="M44.45,25.45 A13.5,13.5 0 0 1 63.55,25.45"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="3.5"
        android:strokeLineCap="round"
        android:fillColor="#00000000" />
</vector>
